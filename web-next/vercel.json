{
  "headers": [
    {
      "source": "/products(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*GPTBot.*"
        }
      ],
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tsebi-production.up.railway.app/api/:path*"
    }
  ]
}

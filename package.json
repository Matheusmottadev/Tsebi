{
  "name": "tsebi-store",
  "version": "1.0.0",
  "private": true,
  "description": "TSEBI storefront with Stripe checkout backend",
  "main": "server/index.js",
  "scripts": {
    "start": "tsx server/index.ts",
    "dev": "tsx watch server/index.ts",
    "build:api": "tsc -p tsconfig.build.json",
    "start:api": "node dist/server/index.js",
    "test:api": "vitest run tests/api --reporter=default",
    "test:api:watch": "vitest tests/api",
    "typecheck": "npm run typecheck:strict",
    "typecheck:strict": "tsc -p tsconfig.strict.json",
    "typecheck:ci": "tsc -p tsconfig.ci.json",
    "typecheck:watch": "tsc -p tsconfig.strict.json --watch",
    "dev:web": "npm --prefix web-next run dev",
    "lint:web": "npm --prefix web-next run lint",
    "typecheck:web": "npm --prefix web-next run typecheck",
    "build:web": "npm --prefix web-next run build",
    "migrate": "node scripts/run-migrations.js",
    "migrate:json": "node scripts/migrate-json-to-db.js",
    "launch:prelaunch": "node scripts/set-launch-mode.js prelaunch",
    "launch:live": "node scripts/set-launch-mode.js launch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@simplewebauthn/server": "^10.0.1",
    "bcrypt": "6.0.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "otpauth": "^9.5.0",
    "pg": "^8.13.1",
    "posthog-node": "^5.21.2",
    "qrcode": "^1.5.4",
    "stripe": "^18.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.18.11",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.8"
  }
}

{
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/JS/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/pages/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/faq.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tsebi-production.up.railway.app/api/:path*"
    },
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/studio-portal",
      "destination": "/pages/studio-portal.html"
    },
    {
      "source": "/studio",
      "destination": "/pages/loading-studio.html"
    },
    {
      "source": "/studio-login",
      "destination": "/pages/studio-login.html"
    },
    {
      "source": "/faq.html",
      "destination": "/pages/faq.html"
    },
    {
      "source": "/:page.html",
      "destination": "/pages/:page.html"
    }
  ]
}

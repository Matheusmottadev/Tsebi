{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tsebi-production.up.railway.app/api/:path*"
    },
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/studio-portal",
      "destination": "/pages/studio-portal.html"
    },
    {
      "source": "/:page.html",
      "destination": "/pages/:page.html"
    }
  ]
}
